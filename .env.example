# .env — Environment variables for WorkForce Hub
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Flask secret key — change this to a long random string in production
SECRET_KEY=workforce-hub-change-this-to-something-long-and-random

# MongoDB connection URI
# Local:  mongodb://localhost:27017/workforce_hub
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/workforce_hub
MONGO_URI=mongodb://localhost:27017/workforce_hub

# Set to False in production
DEBUG=True
